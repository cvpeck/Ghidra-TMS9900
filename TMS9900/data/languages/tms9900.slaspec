# sleigh specification file for TI TMS9900

define endian=big;
define alignment=2;

define space RAM     type=ram_space      size=2  default;
define space register type=register_space size=2;
#define space CRU     type=ram_space      size=2  default;

# 16-bit registers:
#    PC: Program counter
#    WP: Workspace address
#    ST: Status register
define register offset=16 size=2 [ PC WP ST ];
#define register offset=16 size=2 [ r0 r1 r2 r3 r4 r5 r6 r7 r8 r9 r10 r11 r12 r13 r14 r15 PC WP ST ];


# define status bits: 
@define LGT "ST[15,1]" # Logical greater than
@define ST0 "ST[15,1]" # Logical greater than
@define AGT "ST[14,1]" # Arithmetic greater than
@define ST1 "ST[14,1]" # Arithmetic greater than
@define EQ "ST[13,1]"  # Equal
@define ST2 "ST[13,1]"  # Equal
@define C "ST[12,1]"   # Carry
@define ST3 "ST[12,1]"   # Carry
@define O "ST[11,1]"   # Overflow
@define ST4 "ST[11,1]"   # Overflow
@define P "ST[10,1]"   # Parity
@define ST5 "ST[10,1]"   # Parity
@define XOP "ST[9,1]" # XOP instruction executed
@define ST6 "ST[9,1]" # XOP instruction executed
#5-8 unused
@define IM "ST[0,4]" # Interrupt mask

define token data8 (8)
    imm8      = (0,7)
    simm8     = (0,7) signed
;

define token data (16)
    imm16     = (0,15)
	simm16 = (0,15) signed dec
;
define token data2 (16)
    imm216     = (0,15)
	simm216 = (0,15) signed dec
;
# bit 0=MSB in TMS9900, 15 in ghidra
#00 01 02 03 04 05 06 07 08 09 10 11 12 13 14 15
#15 14 13 12 11 10 09 08 07 06 05 04 03 02 01 00

# operand
define token operand (16)
    op3  = (13,15)
	op6  = (10,15)
	op8  = (8,15)
    op10  = (6,15)
    op11  = (5,15)

    doi_b   = (12,12)

    mode_b   = (12,12)
    reg_td  = (10,11)
    reg_dst = (6,9) dec
    reg_dnr = (6,9) 
    xop_dst = (6,9) dec
	reg_ts  = (4,5)
	reg_src = (0,3) dec
	reg_nr = (0,3) 

    crum_op  = (10,15)
    crum_c = (6,9)
	crum_ts  = (4,5)
	crum_src = (0,3) dec

;
	


# dual operand instructions source/reg
define token doir (16)
    doir_op  = (10,15)
#   doir_dst = (6,9) dec
#	doir_ts  = (4,5)
#	doir_src = (0,3) dec
;

# XOP
#define token xop (16)
#    xop_op  = (10,15)
#    xop_dst = (6,9) dec
#	xop_ts  = (4,5)
#	xop_src = (0,3) dec
#;


# single operand instructions 
#define token sop (16)
    #op10  = (6,15)
#	reg_ts  = (4,5)
#	reg_src = (0,3) dec
#;



# CRU Multi
define token crum (16)
#    crum_op  = (10,15)
#    crum_c = (6,9)
#	crum_ts  = (4,5)
#	crum_src = (0,3) dec
;

# CRU Single
define token crus (16)
    crus_op  = (8,15)
    crus_sdis = (0,7) signed
;

# JMP
define token jmp (16)
    jmp_op  = (8,15)
    jmp_sdis = (0,7) signed
;


#SHIFT
define token shift (16)
	shift_op  = (8,15)
	shift_count = (4,7)
	shift_reg = (0,3)
;
#imm
define token iri (16)
    iri_op  = (5,15)
	iri_n_  = (4,4)
	iri_reg = (0,3) dec
;


#load
define token load (16)
    load_op  = (5,15)
    load_n = (0,4)
;
#store

# rtwp

#external





attach names [ reg_dst reg_src iri_reg shift_reg] [
r0 r1 r2 r3 r4 r5 r6 r7 r8 r9 r10 r11 r12 r13 r14 r15 ];

#attach variables acc_4 [ A B ];

################################################################
# Constructors
################################################################

REL:  addr    is jmp_sdis  [ addr = inst_next + ( jmp_sdis *2 );  ]   { export *:2 addr; }

# register source addressing
# Workspace register
SREG: reg_src is reg_src & reg_ts=0  
{ 
	local tmp:2 = WP + 2 * reg_src;
    export *:2 tmp;
} 

# Workspace register indirect
SREG: "*"reg_src is reg_src & reg_ts=1
{ 
	local tmp:2 = WP + 2 * reg_src;
	local tmp2:2 = *:2 tmp;
    export *:2 tmp2;
} 

# Workspace register indirect increment
SREG: "*"^reg_src^"+" is reg_src & reg_ts=3  & reg_nr!=-1
{ 
	local tmp:2 = WP + 2 * reg_src;
	local tmp2:2 = *:2 tmp;
    export *:2 tmp2;
#	
} 
	
# symbolic is only for R0
SREG: "SYM@>"imm16 is reg_src & reg_ts=2 & reg_nr=0 ;imm16
{
	local tmp2:2 = imm16;
	export tmp2;
}

# R1-R15 is indexed
SREG: "@"simm16"("reg_src")" is reg_src & reg_ts=2 & reg_nr!=0 ;simm16
{  
	local tmp:2 = WP + 2 * reg_src ;
	local tmp2:2 = *:2 tmp+simm16;
    export *:2 tmp2;#
}


# register destination addressing
# Workspace register
DREG: reg_dst is reg_dst & reg_td=0  
{ 
	local tmp:2 = WP + 2 * reg_dst;
    export *:2 tmp;
} 

# Workspace register indirect
DREG: "*"reg_dst is reg_dst & reg_td=1
{ 
	local tmp:2 = WP + 2 * reg_dst;
	local tmp2:2 = *:2 tmp;
    export *:2 tmp2;
} 

# Workspace register indirect increment
DREG: "*"^reg_dst^"+" is reg_dst & reg_td=3 
{ 
	local tmp:2 = WP + 2 * reg_dst;
	local tmp2:2 = *:2 tmp;
    export *:2 tmp2;#
#	*tmp2 = *tmp2+1;
#	
} 
	
# symbolic is only for R0 #FIXME reg_ts=2
DREG: "@>"imm216 is reg_dst & reg_td=2 & reg_ts!=2 & reg_dnr=0 ;imm216
{
	local tmp2:2 = imm216;
	export tmp2;
}

# symbolic is only for R0
DREG: "@>"imm216 is reg_dst & reg_td=2  & reg_ts=2  & reg_dnr=0 ;imm16;imm216
{
	local tmp2:2 = imm216;
	export tmp2;

}


# R1-R15 is indexed
DREG: "@"simm16"("reg_dst")" is reg_dst & reg_td=2 & reg_ts!=2 & reg_dnr!=0 ;simm16
{
	local tmp:2 = WP + 2 * reg_dst ;
	local tmp2:2 = *:2 tmp+simm16;
    export *:2 tmp2;#
}

DREG: "@"simm16"("reg_dst")" is reg_dst & reg_td=2 & reg_ts=2 & reg_dnr!=0 ;imm16;simm16
{
	local tmp:2 = WP + 2 * reg_dst ;
	local tmp2:2 = *:2 tmp+simm16;
    export *:2 tmp2;#
}



################################################################
# Macros
################################################################

################################################################
# Instructions
################################################################

# 3.5.1
# A - Add word
:A SREG","^DREG is ( op3=0x5 & mode_b=0 ) ... & SREG ... & DREG
{
    local s:2 = SREG;
    local d:2 = DREG;
    local result:2 = d + s;
    $(LGT) = (result > 0);
    $(AGT) = (result s> 0);
    $(EQ)  = (result == 0);
    $(C)   = (result < d);                          # carry if wrapped
    $(O)   = (((s ^ ~d) & (s ^ result)) >> 15) & 1; # overflow
    DREG = result;
}

# AB - Add byte
:AB SREG","^DREG is ( op3=0x5 & mode_b=1 ) ... & SREG ... & DREG
{
    local s:1 = SREG:1;
    local d:1 = DREG:1;
    local result:1 = d + s;
    $(LGT) = (result > 0);
    $(AGT) = (result s> 0);
    $(EQ)  = (result == 0);
    $(C)   = (result < d);
    $(O)   = (((s ^ ~d) & (s ^ result)) >> 7) & 1;
    $(P)   = popcount(result) & 1;
    DREG = zext(result);
}

# S - Subtract word
:S SREG","^DREG is ( op3=0x3 & mode_b=0 ) ... & SREG ... & DREG
{
    local s:2 = SREG;
    local d:2 = DREG;
    local result:2 = d - s;
    $(LGT) = (result > 0);
    $(AGT) = (result s> 0);
    $(EQ)  = (result == 0);
    $(C)   = (d >= s);                              # carry if no borrow
    $(O)   = (((d ^ s) & (d ^ result)) >> 15) & 1; # overflow
    DREG = result;
}

# SB - Subtract byte
:SB SREG","^DREG is ( op3=0x3 & mode_b=1 ) ... & SREG ... & DREG
{
    local s:1 = SREG:1;
    local d:1 = DREG:1;
    local result:1 = d - s;
    $(LGT) = (result > 0);
    $(AGT) = (result s> 0);
    $(EQ)  = (result == 0);
    $(C)   = (d >= s);
    $(O)   = (((d ^ s) & (d ^ result)) >> 7) & 1;
    $(P)   = popcount(result) & 1;
    DREG = zext(result);
}

# C - Compare word
:C SREG","^DREG is ( op3=0x4 & mode_b=0) ... & SREG ... & DREG
{
    local s:2 = SREG;
    local d:2 = DREG;
    $(LGT) = (d > s);
    $(AGT) = (d s> s);
    $(EQ)  = (d == s);
}

# CB - Compare byte
:CB SREG","^DREG is ( op3=0x4 & mode_b=1 )  ... & SREG ... & DREG
{
    local s:1 = SREG:1;
    local d:1 = DREG:1;
    $(LGT) = (d > s);
    $(AGT) = (d s> s);
    $(EQ)  = (d == s);
    $(P)   = popcount(d) & 1;
}


# SOC - Set ones corresponding word
:SOC SREG","^DREG is ( op3=0x7 & mode_b=0 ) ... & SREG ... & DREG
{
    local result:2 = DREG | SREG;
    $(LGT) = (result > 0);
    $(AGT) = (result s> 0);
    $(EQ)  = (result == 0);
    DREG = result;
}

# SOCB - Set ones corresponding byte
:SOCB SREG","^DREG is ( op3=0x7 & mode_b=1 ) ... & SREG ... & DREG
{
    local result:1 = DREG:1 | SREG:1;
    $(LGT) = (result > 0);
    $(AGT) = (result s> 0);
    $(EQ)  = (result == 0);
    $(P)   = popcount(result) & 1;
    DREG = zext(result);
}

# SZC - Set zeros corresponding word
:SZC SREG","^DREG is ( op3=0x2 & mode_b=0)  ... & SREG ... & DREG
{
    local result:2 = DREG & ~SREG;
    $(LGT) = (result > 0);
    $(AGT) = (result s> 0);
    $(EQ)  = (result == 0);
    DREG = result;
}

# SZCB - Set zeros corresponding byte
:SZCB SREG","^DREG is ( op3=0x2 & mode_b=1 )  ... & SREG ... & DREG
{
    local result:1 = DREG:1 & ~SREG:1;
    $(LGT) = (result > 0);
    $(AGT) = (result s> 0);
    $(EQ)  = (result == 0);
    $(P)   = popcount(result) & 1;
    DREG = zext(result);
}

# MOV - Move word
:MOV SREG","^DREG is ( op3=0x6 & mode_b=0 ) ... & SREG ... & DREG
{
    local tmp:2 = SREG;
    $(LGT) = (tmp > 0);
    $(AGT) = (tmp s> 0);
    $(EQ)  = (tmp == 0);
    DREG = tmp;
}

# MOVB - Move byte
:MOVB SREG^","^DREG is ( op3=0x6 & mode_b=1) ... & SREG ... & DREG
{
    local tmp:1 = SREG:1;       # Take high byte of source
    $(LGT) = (tmp > 0);
    $(AGT) = (tmp s> 0);
    $(EQ)  = (tmp == 0);
    $(P)   = popcount(tmp) & 1; # Parity bit
    DREG = zext(tmp);
}

# 3.5.2
:COC SREG","^reg_dst is ( op6=0x8 & reg_dst ) ... & SREG 
{

}

:CZC SREG","^reg_dst is ( op6=0x9 & reg_dst ) ... & SREG 
{

}

:XOR SREG","^reg_dst is ( op6=0xa & reg_dst ) ... & SREG 
{

}

:MPY SREG","^reg_dst is ( op6=0xe & reg_dst ) ... & SREG 
{

}

:DIV SREG","^reg_dst is ( op6=0xf & reg_dst ) ... & SREG 
{

}

# 3.5.3
:XOP SREG^","^reg_dnr is ( op6=0xb & reg_dnr  ) ...  & SREG 
{
 	local tmpwp:2 = 40 + 2* reg_dnr;
 	local tmppc:2 = 42 + 2* reg_dnr;
	call [tmppc];
    #export *:2 tmp2;
}

#:XOP ">@"imm16^","^reg_dst is ( op6=0xb & reg_dst & reg_ts=0 ) ...  & SREG ;imm16
#{#
#
#}


# 3.5.4
# B - Branch, simple jump to address in source operand
:B SREG is op10=0x11 ... & SREG 
{
    local target:2 = SREG;
    goto [target];
}

# BL - Branch and Link, saves return address in R11
:BL SREG is op10=0x1a ... & SREG 
{
    # Save return address (next instruction) into workspace R11
    local r11_addr:2 = WP + 22;    # R11 = WP + (11 * 2)
    *:2 r11_addr = inst_next;
    
    local target:2 = SREG;
    call [target];
}

# BLWP - Branch and Link with Workspace Pointer
# Performs a full context switch using a vector address
:BLWP SREG is op10=0x10 ... & SREG 
{
    # Read vector address from source operand
    local vector:2 = SREG;
    
    # Read new WP and PC from vector table
    local new_wp:2 = *:2 vector;
    local new_pc:2 = *:2 (vector + 2);
    
    # Save context into NEW workspace registers R13, R14, R15
    local r13_addr:2 = new_wp + 26;   # R13 = new_WP + (13 * 2)
    local r14_addr:2 = new_wp + 28;   # R14 = new_WP + (14 * 2)
    local r15_addr:2 = new_wp + 30;   # R15 = new_WP + (15 * 2)
    
    *:2 r13_addr = WP;          # Save old WP in new R13
    *:2 r14_addr = inst_next;   # Save return PC in new R14
    *:2 r15_addr = ST;          # Save old ST in new R15
    
    # Switch workspace
    WP = new_wp;
    
    call [new_pc];
}

# CLR - Clear operand (set to 0)
:CLR SREG is op10=0x13 ... & SREG 
{
    SREG = 0;
}

# SETO - Set operand to all ones (0xFFFF)
:SETO SREG is op10=0x1c ... & SREG 
{
    SREG = 0xFFFF;
}

# INV - Invert all bits
:INV SREG is op10=0x15 ... & SREG 
{
    local tmp:2 = ~SREG;
    # Set status bits
    $(LGT) = (tmp > 0);
    $(AGT) = (tmp s> 0);
    $(EQ)  = (tmp == 0);
    SREG = tmp;
}

# NEG - Negate (two's complement)
:NEG SREG is op10=0x14 ... & SREG 
{
    local tmp:2 = -SREG;
    # Set status bits
    $(LGT) = (tmp > 0);
    $(AGT) = (tmp s> 0);
    $(EQ)  = (tmp == 0);
    $(C)   = (SREG != 0);
    $(O)   = (SREG == 0x8000);
    SREG = tmp;
}

# ABS - Absolute value
:ABS SREG is op10=0x1d ... & SREG 
{
    local tmp:2 = SREG;
    local result:2;
    $(O) = (tmp == 0x8000);
    if (tmp s>= 0) goto <positive>;
        result = -tmp;
        goto <done>;
    <positive>
        result = tmp;
    <done>
    $(LGT) = (result > 0);
    $(AGT) = (result s> 0);
    $(EQ)  = (result == 0);
    $(C)   = 0;
    SREG = result;
}

# SWPB - Swap bytes
:SWPB SREG is op10=0x1b ... & SREG 
{
    local tmp:2 = SREG;
    local hi:1 = tmp(1);    # high byte
    local lo:1 = tmp:1;     # low byte
    local result:2 = (zext(lo) << 8) | zext(hi);
    SREG = result;
}

# INC - Increment by 1
:INC SREG is op10=0x16 ... & SREG 
{
    local tmp:2 = SREG + 1;
    $(LGT) = (tmp > 0);
    $(AGT) = (tmp s> 0);
    $(EQ)  = (tmp == 0);
    $(C)   = (tmp == 0);           # carry if wrapped around
    $(O)   = (SREG == 0x7FFF);    # overflow if was max positive
    SREG = tmp;
}

# INCT - Increment by 2
:INCT SREG is op10=0x17 ... & SREG 
{
    local tmp:2 = SREG + 2;
    $(LGT) = (tmp > 0);
    $(AGT) = (tmp s> 0);
    $(EQ)  = (tmp == 0);
    $(C)   = (tmp <  2);           # carry if wrapped around
    $(O)   = (SREG == 0x7FFF) || (SREG == 0x7FFE);
    SREG = tmp;
}

# DEC - Decrement by 1
:DEC SREG is op10=0x18 ... & SREG 
{
    local tmp:2 = SREG - 1;
    $(LGT) = (tmp > 0);
    $(AGT) = (tmp s> 0);
    $(EQ)  = (tmp == 0);
    $(C)   = (SREG != 0);         # carry if no borrow
    $(O)   = (SREG == 0x8000);   # overflow if was min negative
    SREG = tmp;
}

# DECT - Decrement by 2
:DECT SREG is op10=0x19 ... & SREG 
{
    local tmp:2 = SREG - 2;
    $(LGT) = (tmp > 0);
    $(AGT) = (tmp s> 0);
    $(EQ)  = (tmp == 0);
    $(C)   = (SREG > 1);          # carry if no borrow
    $(O)   = (SREG == 0x8000) || (SREG == 0x8001);
    SREG = tmp;
}

# X - Execute instruction at source address
:X SREG is op10=0x12 ... & SREG 
{
    # X executes the instruction at the source address
    # This is difficult to model statically, treated as indirect call
    local target:2 = SREG;
    call [target];
}


# 3.5.5 CRU multi
:LDCR SREG^","^crum_c is ( crum_op=0xc & crum_c ) ... & SREG 
{

}
:STCR SREG^","^crum_c is ( crum_op=0xd & crum_c ) ... & SREG 
{

}

# 3.5.6 CRU single bit
:SBO crus_sdis is crus_op=0x1d & crus_sdis
{

}
:SBZ crus_sdis is crus_op=0x1e & crus_sdis
{

}
:TB crus_sdis is crus_op=0x1f & crus_sdis
{

}

# 3.5.7
:JEQ ">"^REL is jmp_op=0x13 & REL 
{
 if ($(ST2) == 1) goto REL;
}

:JGT ">"^REL is jmp_op=0x15 & REL 
{
 if ($(ST1) == 1) goto REL;
}

:JH ">"^REL is jmp_op=0x1b & REL 
{
 if (($(ST0) == 1) && ($(ST2) == 0) ) goto REL;
}
:JHE ">"^REL is jmp_op=0x14 & REL 
{
 if (($(ST0) == 1) && ($(ST2) == 1) ) goto REL;
}
:JL ">"^REL is jmp_op=0x1a & REL 
{
 if (($(ST0) == 0) && ($(ST2) == 0) ) goto REL;
}
:JLE ">"^REL is jmp_op=0x12 & REL 
{
 if (($(ST0) == 0) && ($(ST2) == 1) ) goto REL;
}
:JLT ">"^REL is jmp_op=0x11 & REL 
{
 if (($(ST1) == 0) && ($(ST2) == 0) ) goto REL;
}
:JMP ">"^REL is jmp_op=0x10 & REL 
{
 goto REL;
}
:JNC ">"^REL is jmp_op=0x17 & REL 
{
 if ($(ST3) == 0) goto REL;
}
:JNE ">"^REL is jmp_op=0x16 & REL 
{
 if ($(ST2) == 0) goto REL;
}
:JNO ">"^REL is jmp_op=0x19 & REL 
{
 if ($(ST4) == 0) goto REL;
}
:JOC ">"^REL is jmp_op=0x18 & REL 
{
 if ($(ST3) == 1) goto REL;
}
:JOP ">"^REL is jmp_op=0x1c & REL 
{
 if ($(ST5) == 1) goto REL;
}






# 3.5.8
:SLA shift_reg^","^shift_count is shift_op=0x0a  & shift_reg & shift_count
{

}
:SRA shift_reg^","^shift_count is shift_op=0x08  & shift_reg & shift_count
{

}
:SRC shift_reg^","^shift_count is shift_op=0x0b  & shift_reg & shift_count
{

}
:SRL shift_reg^","^shift_count is shift_op=0x09  & shift_reg & shift_count
{

}

# 3.5.9
# LI - Load immediate
:LI iri_reg^",>"^imm16 is iri_op=0x10 & iri_reg; imm16
{
    local tmp:2 = imm16;
    local reg_addr:2 = WP + (2 * iri_reg);
    $(LGT) = (tmp > 0);
    $(AGT) = (tmp s> 0);
    $(EQ)  = (tmp == 0);
    *:2 reg_addr = tmp;
}

# AI - Add immediate
:AI iri_reg^",>"^imm16 is iri_op=0x11 & iri_reg; imm16
{
    local reg_addr:2 = WP + (2 * iri_reg);
    local d:2 = *:2 reg_addr;
    local s:2 = imm16;
    local result:2 = d + s;
    $(LGT) = (result > 0);
    $(AGT) = (result s> 0);
    $(EQ)  = (result == 0);
    $(C)   = (result < d);
    $(O)   = (((s ^ ~d) & (s ^ result)) >> 15) & 1;
    *:2 reg_addr = result;
}

# ANDI - And immediate
:ANDI iri_reg^",>"^imm16 is iri_op=0x12 & iri_reg; imm16
{
    local reg_addr:2 = WP + (2 * iri_reg);
    local result:2 = *:2 reg_addr & imm16;
    $(LGT) = (result > 0);
    $(AGT) = (result s> 0);
    $(EQ)  = (result == 0);
    *:2 reg_addr = result;
}

# ORI - Or immediate
:ORI iri_reg^",>"^imm16 is iri_op=0x13 & iri_reg; imm16
{
    local reg_addr:2 = WP + (2 * iri_reg);
    local result:2 = *:2 reg_addr | imm16;
    $(LGT) = (result > 0);
    $(AGT) = (result s> 0);
    $(EQ)  = (result == 0);
    *:2 reg_addr = result;
}

# CI - Compare immediate
:CI iri_reg^",>"^imm16 is iri_op=0x14 & iri_reg; imm16
{
    local reg_addr:2 = WP + (2 * iri_reg);
    local d:2 = *:2 reg_addr;
    local s:2 = imm16;
    $(LGT) = (d > s);
    $(AGT) = (d s> s);
    $(EQ)  = (d == s);
}

# 3.5.10
# LWPI - Load workspace pointer immediate
:LWPI ">"^imm16 is load_op=0x17; imm16
{
    WP = imm16;
}

# LIMI - Load interrupt mask immediate
:LIMI ">"^imm16 is load_op=0x18; imm16
{
    $(IM) = imm16:1 & 0xF;
}

# 3.5.11
# STST - Store status register
:STST reg_dst is op11=0x16 & reg_dst
{
    local reg_addr:2 = WP + (2 * reg_dst);
    *:2 reg_addr = ST;
}

# STWP - Store workspace pointer
:STWP reg_dst is op11=0x15 & reg_dst
{
    local reg_addr:2 = WP + (2 * reg_dst);
    *:2 reg_addr = WP;
}

# 3.5.12
# RTWP - Return with Workspace Pointer restore
:RTWP is op11=0x1c
{
    # Restore context from current R13, R14, R15
    local r13_addr:2 = WP + 26;   # R13 = WP + (13 * 2)
    local r14_addr:2 = WP + 28;   # R14 = WP + (14 * 2)
    local r15_addr:2 = WP + 30;   # R15 = WP + (15 * 2)
    
    WP = *:2 r13_addr;            # Restore old WP
    ST = *:2 r15_addr;            # Restore old ST
    
    local ret_addr:2 = *:2 r14_addr;  # Get return PC
    return [ret_addr];
}





